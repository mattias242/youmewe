# SMTP-konfiguration för mejlutskick
# Kopiera till .env och fyll i dina uppgifter

# Gmail: använd ett App Password (inte ditt vanliga lösenord)
# Skapa under: Google-konto → Säkerhet → Tvåstegsverifiering → Applösenord
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=din@gmail.com
SMTP_PASS=ditt-app-password
SMTP_FROM=YouMeWe <din@gmail.com>
